{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "vc-brain/founder",
  "title": "Founder",
  "description": "The persistent founder record in Memory. The Founder Score lives here: it follows the person across companies and applications, updates on new signals, and never resets. Contract between the Memory track and the Intelligence track — change only by agreement.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "links", "first_seen", "last_updated", "founder_score", "signal_ids", "companies"],
  "properties": {
    "id": { "type": "string", "description": "Stable id, e.g. fndr-0001. Never reused." },
    "name": { "type": "string" },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "github": { "type": ["string", "null"] },
        "linkedin": { "type": ["string", "null"] },
        "twitter": { "type": ["string", "null"] },
        "site": { "type": ["string", "null"] }
      }
    },
    "location": { "type": ["string", "null"] },
    "first_seen": { "type": "string", "description": "ISO 8601 — when the system first observed this person, via any signal." },
    "last_updated": { "type": "string", "description": "ISO 8601 — last founder_score or profile update." },
    "founder_score": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "band", "confidence", "evidence_count", "cold_start", "history"],
      "properties": {
        "value": { "type": "integer", "description": "0-100. One input into the Founder axis — never a substitute for it." },
        "band": {
          "type": "array",
          "items": { "type": "integer" },
          "description": "[low, high] confidence band. Thin evidence = wide band, stated plainly — never a silently precise number. Cold-start founders get a wide band, not a low value."
        },
        "confidence": { "type": "string", "enum": ["high", "medium", "low", "speculative"] },
        "evidence_count": { "type": "integer", "description": "Number of distinct signals contributing." },
        "cold_start": { "type": "boolean", "description": "True when the score rests on public footprint only — no funding history, no shipped-product history." },
        "history": {
          "type": "array",
          "description": "Append-only. Every score change carries its reason and triggering signal.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["at", "value", "reason"],
            "properties": {
              "at": { "type": "string" },
              "value": { "type": "integer" },
              "reason": { "type": "string" },
              "signal_id": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "signal_ids": { "type": "array", "items": { "type": "string" } },
    "companies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["company_id", "role"],
        "properties": {
          "company_id": { "type": "string" },
          "role": { "type": "string" },
          "from": { "type": ["string", "null"] },
          "to": { "type": ["string", "null"] }
        }
      }
    },
    "notes": { "type": "string" }
  }
}
